# ═══════════════════════════════════════════════════════════════
# ai_app1 环境变量模板
# 复制为 .env 并填入真实值：
#     cp ai_app1/.env.example ai_app1/.env
#
# 说明：
#   • ai_app2 / ai_app3 / rag_framework 会自动回退读取 ai_app1/.env
#   • 所有以 RAG_ 为前缀的变量优先级高于兼容旧命名
# ═══════════════════════════════════════════════════════════════

# ── LLM API（必填）─────────────────────────────────────────────
# 实际使用 MiniMax API（OpenAI 兼容格式）
OPENAI_API_KEY=your_minimax_key

# 或通过 RAG_ 前缀精确控制（优先级更高）
# RAG_LLM_API_KEY=your_minimax_key
# RAG_LLM_BACKEND=minimax        # minimax | ollama | openai | local
# RAG_LLM_BASE_URL=https://api.minimaxi.com/v1
# RAG_LLM_MODEL=MiniMax-M2.7
# RAG_LLM_MAX_TOKENS=512

# ── HuggingFace（下载模型用，可选）──────────────────────────────
# 需要下载私有/门控模型时填写；公开模型留空即可
# HF_TOKEN=your_huggingface_token

# 中国大陆镜像（脚本默认自动走 hf-mirror）
# 要直连官方 Hub：设为空值或删除此行
# HF_ENDPOINT=https://hf-mirror.com

# ── 可选：下载脚本调优 ─────────────────────────────────────────
# HF_MAX_WORKERS=4
# HF_HUB_ETAG_TIMEOUT=30
# HF_DISK_STATS_INTERVAL=60
# HF_DOWNLOAD_RETRIES=5
# HF_DOWNLOAD_UNLOCK=0
# HF_IMPLICIT_TOKEN=0
# QWEN_REWRITER_REPO_ID=Qwen/Qwen2.5-1.5B-Instruct
