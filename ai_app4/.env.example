# ai_app4 环境变量配置
# 复制为 .env 并填入真实值

# ── 客服系统行为 ───────────────────────────────────────
CS4_ENABLE_ESCALATION=true
CS4_ESCALATION_SENTIMENT_THRESHOLD=negative
CS4_ENABLE_TORCH_MODELS=true
CS4_ENABLE_AGENT_HANDOFF=false

# ── 会话配置 ───────────────────────────────────────────
CS4_SESSION_TTL_SECONDS=3600
CS4_MAX_HISTORY_PER_SESSION=20

# ── LLM 配置（继承 RAGSettings，前缀仍为 RAG_） ─────────
RAG_LLM_BACKEND=minimax
RAG_LLM_API_KEY=your_api_key_here
RAG_LLM_MODEL=MiniMax-M2.7

# ── LlamaIndex 配置 ────────────────────────────────────
RAG_LLAMAINDEX_ENABLED=false
RAG_LLAMAINDEX_INDEX_TYPE=vector
RAG_LLAMAINDEX_RESPONSE_MODE=no_text

# ── PyTorch 模型路径（可选，留空使用默认 HuggingFace 模型） ──
RAG_TORCH_DEVICE=auto
RAG_TORCH_INTENT_MODEL_PATH=
RAG_TORCH_SENTIMENT_MODEL_PATH=
RAG_TORCH_NER_MODEL_PATH=
