# ai_app4 环境变量配置
# 复制为 .env 并填入真实值

# ── 客服系统行为 ───────────────────────────────────────
CS4_ENABLE_ESCALATION=true
CS4_ESCALATION_SENTIMENT_THRESHOLD=negative
CS4_ENABLE_TORCH_MODELS=true
CS4_ENABLE_AGENT_HANDOFF=false

# ── 会话配置 ───────────────────────────────────────────
CS4_SESSION_TTL_SECONDS=3600
CS4_MAX_HISTORY_PER_SESSION=20

# ── LLM 配置（继承 RAGSettings，前缀仍为 RAG_） ─────────
RAG_LLM_BACKEND=minimax
RAG_LLM_API_KEY=your_api_key_here
RAG_LLM_MODEL=MiniMax-M2.7

# ── LlamaIndex 配置 ────────────────────────────────────
RAG_LLAMAINDEX_ENABLED=false
RAG_LLAMAINDEX_INDEX_TYPE=vector
RAG_LLAMAINDEX_RESPONSE_MODE=no_text

# ── PyTorch 模型路径（可选，留空使用默认 HuggingFace 模型） ──
RAG_TORCH_DEVICE=auto
RAG_TORCH_INTENT_MODEL_PATH=
RAG_TORCH_SENTIMENT_MODEL_PATH=
RAG_TORCH_NER_MODEL_PATH=

# ═════════════════════════════════════════════════════════════
# 商业版 Wealth AI Agent 新增配置（2026-05-17）
# ═════════════════════════════════════════════════════════════

# ── 外部实时数据源 ───────────────────────────────────────
WEALTH_YAHOO_FINANCE_ENABLED=true              # 启用 Yahoo Finance（无需 API Key）
WEALTH_FRED_API_ENABLED=false                  # 启用 FRED 宏观数据（需 API Key）
WEALTH_FRED_API_KEY=your_fred_api_key_here     # FRED API Key（申请：https://fred.stlouisfed.org/docs/api/api_key.html）
WEALTH_TAVILY_SEARCH_ENABLED=false             # 启用 Tavily 实时网络搜索（需 API Key）
WEALTH_TAVILY_API_KEY=your_tavily_api_key_here # Tavily API Key（申请：https://tavily.com/）
WEALTH_TAVILY_SEARCH_DEPTH=basic               # Tavily 搜索深度: basic | advanced
WEALTH_TAVILY_MAX_RESULTS=3                    # Tavily 单次返回结果数（建议 3-5）

# ── 三轨融合检索 ─────────────────────────────────────────
WEALTH_THREE_TRACK_ENABLED=true                # 启用三轨融合（本地 RAG + 金融 API + 网络搜索）
WEALTH_TRACK_A_WEIGHT=1.0                      # 本地 RAG 权重
WEALTH_TRACK_B_WEIGHT=0.95                     # 金融 API 权重
WEALTH_TRACK_C_WEIGHT=0.85                     # 网络搜索权重

# ── 商业合规与来源标注 ───────────────────────────────────
WEALTH_ENABLE_SOURCE_ATTRIBUTION=true          # 在回复末尾标注数据来源
WEALTH_ENABLE_COMPLIANCE_DISCLAIMER=true       # 在回复末尾追加投资免责声明

# ── 缓存与配额（可选高级配置）────────────────────────────
WEALTH_CACHE_TTL_SECONDS=300                   # 结构化数据缓存 TTL（默认 5 分钟）
WEALTH_QUOTA_DAILY_LIMIT=1000                  # 单日 API 调用上限（按 user_id）
WEALTH_QUOTA_HOURLY_LIMIT=200                  # 单小时 API 调用上限
